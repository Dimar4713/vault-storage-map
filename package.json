{
  "name": "vault-storage-map",
  "version": "1.0.5",
  "description": "Multilingual visual disk-usage analyzer for local vaults.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "check": "tsc -noEmit -skipLibCheck"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "storage",
    "treemap",
    "disk-usage"
  ],
  "author": "AIMETON · Dimar4713",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^22.10.0",
    "esbuild": "^0.25.0",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "5.7.2"
  }
}
